meta {
  name: Update data provider
  type: http
  seq: 5
}

put {
  url: {{host}}/api/v1/data-providers/{{providerName}}
  body: json
  auth: inherit
}

body:json {
  {
    /* 
     * learn more [here](https://docs.embeddable.com/data/cube-cloud) 
     */
    "type": "cube",
    "credentials": {
      "secretKey": "{{secretKey}}",
      "instanceUrl": "{{instanceUrl}}"
    }
  }
  
}

settings {
  encodeUrl: true
  timeout: 0
}
