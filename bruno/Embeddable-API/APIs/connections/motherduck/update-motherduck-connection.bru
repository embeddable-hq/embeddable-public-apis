meta {
  name: Update Motherduck Connection
  type: http
  seq: 2
}

put {
  url: {{host}}/api/v1/connections/{{connectionName}}
  body: json
  auth: inherit
}

body:json {
  {
    /* 
     * learn more [here](https://docs.embeddable.com/data/connect-your-database) 
     */
    "name": "{{connectionName}}",
    "type": "duckdb",
    "credentials": {
      "motherDuckToken": "{{motherDuckToken}}"
    }
  }
  
}

settings {
  encodeUrl: true
  timeout: 0
}
